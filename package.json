{
  "name": "youaremyhome-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:couples-app": "npm run dev --workspace=apps/couples-app",
    "dev:home-game": "npm run dev --workspace=apps/home-game",
    "build": "npm run build --workspace=apps/couples-app && npm run build --workspace=apps/home-game",
    "lint": "npm run lint --workspace=apps/couples-app"
  }
}
