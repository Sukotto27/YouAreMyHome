rules_version = '2';

// This app has no public sign-up — the only two accounts are created by hand
// in the Firebase console, so gating on "signed in" is equivalent to gating
// on "one of the two of us."
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
